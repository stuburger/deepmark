// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`renderCoverDocument > renders the class cover with summary table for a multi-student class 1`] = `"<!doctype html><html lang="en"><head><meta charSet="utf-8"/><title>Year 10 Set 2 — Cover</title></head><body><section class="cover"><h1 class="h1">Class report</h1><p class="small-muted">GCSE Maths Paper 1</p><div class="meta-line"><span>Class: Year 10 Set 2</span><span>Teacher: Mx Bourhill</span><span>Generated 07 May 2026</span></div><div class="meta-line"><span>2 submissions</span><span>Class average: 70%</span></div><div style="margin-top:20pt"><h3 class="h3">Summary</h3><table class="summary-table"><thead><tr><th>Student</th><th class="col-marks">Marks</th><th class="col-percent">%</th></tr></thead><tbody><tr><td>Pat Doe</td><td class="col-marks">3/5</td><td class="col-percent score-warn">60%</td></tr><tr><td>Jamie Roe</td><td class="col-marks">4/5</td><td class="col-percent score-good">80%</td></tr></tbody></table></div></section></body></html>"`;
