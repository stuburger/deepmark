// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`renderLegendDocument > matches a stable snapshot for the canonical legend (with AOs) 1`] = `"<!doctype html><html lang="en"><head><meta charSet="utf-8"/><title>Year 10 Set 2 — Annotation key</title></head><body><section class="legend"><h1 class="h1">Annotation key</h1><div class="legend-block"><h3 class="h3 muted">Mark signals</h3><div class="legend-row"><span class="legend-signal" style="color:#16A34A;font-weight:700">+  Tick</span><span class="legend-meaning muted">Creditworthy point</span></div><div class="legend-row"><span class="legend-signal" style="color:#DC2626;font-weight:700">×  Cross</span><span class="legend-meaning muted">Incorrect or irrelevant</span></div><div class="legend-row"><span class="legend-signal" style="color:#3B82F6;font-weight:700">Underline</span><span class="legend-meaning muted">Applied or contextualised knowledge</span></div><div class="legend-row"><span class="legend-signal" style="color:#166534;font-weight:700">Double underline</span><span class="legend-meaning muted">Developed reasoning or analysis chain</span></div><div class="legend-row"><span class="legend-signal" style="color:#9333EA;font-weight:700">Box</span><span class="legend-meaning muted">Key term or concept</span></div><div class="legend-row"><span class="legend-signal" style="color:#D97706;font-weight:700">Circle</span><span class="legend-meaning muted">Vague or unclear expression</span></div></div><div class="legend-block"><h3 class="h3 muted">Chain highlights</h3><div class="legend-row legend-chain-row"><span class="legend-swatch" style="background-color:#DBEAFE"></span><span class="muted">Reasoning connective</span></div><div class="legend-row legend-chain-row"><span class="legend-swatch" style="background-color:#FEF3C7"></span><span class="muted">Evaluation connective</span></div><div class="legend-row legend-chain-row"><span class="legend-swatch" style="background-color:#EDE9FE"></span><span class="muted">Judgement indicator</span></div></div><div class="legend-block"><h3 class="h3 muted">Assessment objectives (this class)</h3><div class="legend-ao-row"><span class="legend-ao-badge" style="color:#3b82f6;border-color:#3b82f6">AO1</span><span class="legend-ao-badge" style="color:#ec4899;border-color:#ec4899">AO2</span></div></div></section></body></html>"`;
