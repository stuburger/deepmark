// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`renderStudentDocument (unannotated) > renders mixed MCQ + written results for a single student 1`] = `"<!doctype html><html lang="en"><head><meta charSet="utf-8"/><title>Pat Doe — GCSE Maths Paper 1</title></head><body><section class="student-section"><header class="student-header"><div><h1 class="h1">Pat Doe</h1><p class="small-muted">GCSE Maths Paper 1</p></div><div class="right"><h2 class="h2 score-warn" style="margin-bottom:0">3/5 (60%)</h2></div></header><div class="rule"></div><div class="question-card"><h3 class="h3">Multiple choice questions</h3><table class="mcq-table"><thead><tr><th class="col-q">Q</th><th class="col-correct">Correct</th><th>Student</th><th class="col-mark">Mark</th></tr></thead><tbody><tr><td class="col-q">Q1</td><td class="col-correct">A</td><td>A</td><td class="col-mark score-good">1/1</td></tr><tr><td class="col-q">Q2</td><td class="col-correct">B</td><td>C</td><td class="col-mark score-bad">0/1</td></tr></tbody><tfoot><tr><td class="col-q">Total</td><td class="col-correct"></td><td></td><td class="col-mark">1/2</td></tr></tfoot></table></div><div class="question-card"><div class="question-header"><span class="question-number">Q3</span><span class="question-score score-warn">2/4</span></div><p class="question-text">Explain how X causes Y.</p><div class="answer-box"><p class="answer-text">Because reasons.</p></div><div class="bullet-heading www">What went well</div><ul class="bullet-list"><li>Identified the cause</li></ul><div class="bullet-heading ebi">Even better if</div><ul class="bullet-list"><li>Develop the reasoning further</li></ul></div></section></body></html>"`;
