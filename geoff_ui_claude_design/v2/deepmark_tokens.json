{
  "$schema": "https://deepmark.ai/tokens/v1",
  "version": "2.0",
  "description": "DeepMark Design Tokens — drop into Tailwind config or CSS :root",

  "color": {
    "accent":         { "value": "#3A96C3",              "usage": "Primary CTA, active states, toolbar border, confirm buttons" },
    "accent-dark":    { "value": "#2878A8",              "usage": "Hover state on primary buttons; active sidebar; avatar bg" },
    "accent-light":   { "value": "rgba(58,150,195,0.08)", "usage": "Subtle tinted backgrounds behind accent elements" },
    "accent-border":  { "value": "rgba(58,150,195,0.25)", "usage": "Accent-coloured borders" },
    "teal-600":       { "value": "#2878A8",              "usage": "Override: pin scale-600 to v2 active/dark blue" },
    "ink":            { "value": "#0C0C0C",              "usage": "All body text, headings, wordmark — near-black, not pure" },
    "ink-secondary":  { "value": "rgba(0,0,0,0.44)",    "usage": "Supporting text, descriptions" },
    "ink-tertiary":   { "value": "rgba(0,0,0,0.28)",    "usage": "Labels, eyebrows, metadata" },
    "ink-disabled":   { "value": "rgba(0,0,0,0.18)",    "usage": "Disabled states" },
    "error":          { "value": "#C04444",              "usage": "Destructive actions and error states only — never brand" },
    "success":        { "value": "#1E8A5E",              "usage": "Confirmed / complete states" },
    "warning":        { "value": "#C4883A",              "usage": "Warning states" }
  },

  "status": {
    "marking":  { "value": "rgba(255,0,0,0.5)", "usage": "Paper card border + badge — actively marking" },
    "review":   { "value": "#7FFFA7",           "usage": "Paper card border + badge — ready for review" },
    "done":     { "value": "rgba(0,0,0,0.09)", "usage": "Neutral — done is quiet" }
  },

  "kanban-phase": {
    "queued":   { "value": "rgba(0,0,0,0.12)", "usage": "Chip border — queued phase" },
    "extract":  { "value": "#E8A83A",           "usage": "Chip border — extracting phase" },
    "grading":  { "value": "#3A96C3",           "usage": "Chip border — grading phase" },
    "annotate": { "value": "#9B6DD4",           "usage": "Chip border — annotating phase" }
  },

  "grade": {
    "9": { "border": "#2E7D32", "bg": "#E8F5E9", "text": "#1B5E20", "threshold": "90%" },
    "8": { "border": "#1565C0", "bg": "#E3F2FD", "text": "#0D47A1", "threshold": "80%" },
    "7": { "border": "#00838F", "bg": "#E0F7FA", "text": "#006064", "threshold": "70%" },
    "6": { "border": "#7B1FA2", "bg": "#F3E5F5", "text": "#4A148C", "threshold": "60%" },
    "5": { "border": "#F9A825", "bg": "#FFF8E1", "text": "#7A5100", "threshold": "50%" },
    "4": { "border": "#E65100", "bg": "#FFF3E0", "text": "#BF360C", "threshold": "40%" },
    "3": { "border": "#C62828", "bg": "#FCE4EC", "text": "#880E4F", "threshold": "30%" },
    "2": { "border": "#795548", "bg": "#EFEBE9", "text": "#3E2723", "threshold": "20%" },
    "1": { "border": "#9E9E9E", "bg": "#F5F5F5", "text": "#616161", "threshold": "<20%" }
  },

  "background": {
    "page":         { "value": "#EFF0F0",       "usage": "Page background — used with horizontal ruled lines" },
    "surface":      { "value": "#F7F8F8",       "usage": "Sidebar / muted panel background" },
    "white":        { "value": "#FFFFFF",       "usage": "Cards, tiles, chips — always white" },
    "texture-image":{ "value": "repeating-linear-gradient(to bottom, transparent 0, transparent 27px, rgba(0,0,0,0.042) 27px, rgba(0,0,0,0.042) 28px)", "usage": "Horizontal ruled lines, evokes exam paper" },
    "texture-size": { "value": "auto",          "usage": "Background-size — let the gradient handle its own period" }
  },

  "border": {
    "default":  { "value": "rgba(0,0,0,0.10)", "usage": "Default border on inputs, cards" },
    "subtle":   { "value": "rgba(0,0,0,0.065)", "usage": "Cards, tiles" },
    "quiet":    { "value": "rgba(0,0,0,0.05)", "usage": "Section dividers, footers, hairlines" },
    "accent":   { "value": "rgba(58,150,195,0.35)", "usage": "Floating toolbar border — accent blue" }
  },

  "shadow": {
    "tile":    { "value": "3px 3px 0px rgba(0,0,0,0.12), 1px 1px 4px rgba(0,0,0,0.07)", "usage": "Script reader tiles only — retained from v1.1" },
    "card":    { "value": "0 2px 6px rgba(0,0,0,0.06), 0 8px 24px rgba(0,0,0,0.045)",   "usage": "Dashboard / shell cards — soft diffuse two-layer" },
    "card-hover": { "value": "0 4px 14px rgba(0,0,0,0.09), 0 14px 36px rgba(0,0,0,0.07)", "usage": "Card hover state" },
    "hero":    { "value": "0 2px 8px rgba(0,0,0,0.07), 0 8px 28px rgba(0,0,0,0.05)",     "usage": "Hero / greeting card" },
    "btn":     { "value": "0 1px 3px rgba(0,0,0,0.06)",                                  "usage": "Secondary buttons — soft shallow" },
    "confirm": { "value": "0 2px 10px rgba(58,150,195,0.32)",                            "usage": "Primary CTA + confirm button — soft brand glow" },
    "float":   { "value": "0 20px 60px rgba(0,0,0,0.18), 0 6px 20px rgba(0,0,0,0.10)",   "usage": "Modals and dialogs" },
    "toolbar": { "value": "0 4px 16px rgba(0,0,0,0.22), 0 1px 4px rgba(58,150,195,0.18)", "usage": "Floating editing toolbar only" },
    "sidebar": { "value": "4px 0 24px rgba(0,0,0,0.14), 2px 0 6px rgba(0,0,0,0.07)",     "usage": "Expanded sidebar" }
  },

  "radius": {
    "sm":  { "value": "5px",  "usage": "Universal default — buttons, inputs, badges, chips, cards, all UI" },
    "md":  { "value": "8px",  "usage": "Upload zones, callout panels, expandable feedback panels" },
    "lg":  { "value": "10px", "usage": "Dialogs, modals, floating toolbar — nothing else" }
  },

  "typography": {
    "font-ui":       { "value": "'Geist', sans-serif",              "usage": "All UI text — replaces Inter everywhere" },
    "font-mono":     { "value": "'Geist Mono', monospace",          "usage": "Numbers, scores, eyebrows, data labels" },
    "font-editorial":{ "value": "'Playfair Display', Georgia, serif","usage": "Dashboard greeting only — one use" },

    "size": {
      "xs":   { "value": "9px",  "usage": "Eyebrows, badges, tiny labels" },
      "sm":   { "value": "11px", "usage": "Secondary labels, metadata" },
      "base": { "value": "12px", "usage": "Body text, card content" },
      "md":   { "value": "13px", "usage": "Standard UI text, button labels" },
      "lg":   { "value": "15px", "usage": "Nav items, prominent labels" },
      "xl":   { "value": "22px", "usage": "Section headings" },
      "2xl":  { "value": "24px", "usage": "Dialog titles" },
      "hero": { "value": "44px", "usage": "Playfair Display greeting only" }
    },

    "weight": {
      "normal":  { "value": "400" },
      "medium":  { "value": "500" },
      "semibold":{ "value": "600" }
    },

    "tracking": {
      "tight":  { "value": "-0.02em", "usage": "Headings in Geist" },
      "snug":   { "value": "-0.01em", "usage": "UI labels, button text" },
      "wide":   { "value": "0.14em",  "usage": "Eyebrows, uppercase labels in Geist Mono" },
      "wider":  { "value": "0.18em",  "usage": "Section eyebrows" }
    }
  },

  "rules": {
    "no-pill-radius":  "Maximum border-radius is 10px (dialogs/toolbar only). 5px everywhere else. No 20px+ pills.",
    "shadows":         "Cards use soft diffuse two-layer (--shadow-card). Primary CTAs use soft brand glow (--shadow-confirm). Hard SE-offset shadows are retained for the script reader only (--shadow-tile).",
    "no-purple":       "Purple #6B4FA0 is forbidden. Accent is blue #3A96C3 only.",
    "chip-bg-always-white": "Kanban chips always have white background in every phase including Done. Only border colour changes.",
    "chip-pct-bold":   "In Done chips, the percentage is font-weight: 700. Grade label is font-weight: 400 alongside it.",
    "toolbar-elements": "Floating toolbar element order: B I U | tick(1) cross(2) underline(3) arrows(4) cube(5) circle(6) link(7) | eraser | hint",
    "accent-as-punctuation": "Accent blue appears as punctuation only — one primary CTA, active states, confirm buttons, one element per icon."
  }
}
