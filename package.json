{
	"name": "mcp-gcse",
	"type": "module",
	"bin": {
		"weather": "./build/index.js"
	},
	"dependencies": {
		"@aws-sdk/client-sqs": "^3.862.0",
		"@hono/swagger-ui": "^0.5.2",
		"@modelcontextprotocol/sdk": "^1.17.1",
		"@openauthjs/openauth": "0.4.3",
		"mongodb": "7.1.0",
		"sst": "^4.6.11",
		"ts-node": "^10.9.2",
		"valibot": "1.1.0",
		"zod": "^4.3.5"
	},
	"devDependencies": {
		"@biomejs/biome": "1.9.4",
		"@tsconfig/node22": "22.0.1",
		"@types/aws-lambda": "8.10.150",
		"@types/bun": "1.2.12",
		"@types/node": "^24.0.3",
		"@types/sharp": "^0.32.0",
		"sharp": "^0.34.5",
		"turbo": "^2.3.3",
		"typescript": "^5.8.3",
		"vite-tsconfig-paths": "^6.1.1"
	},
	"workspaces": ["packages/*", "apps/*"],
	"scripts": {
		"test:unit": "vitest run --project shared:unit --project backend:unit",
		"test:integration": "sst shell -- vitest run --project 'backend:integration' --project 'web:integration'",
		"process-logo": "bun scripts/process-logo.ts",
		"build": "turbo build",
		"typecheck": "turbo typecheck",
		"check": "bunx biome check apps/web/src packages/backend/src packages/shared/src packages/db/src",
		"fix": "bunx biome check --fix --unsafe apps/web/src packages/backend/src packages/shared/src packages/db/src",
		"dev": "sst dev",
		"deploy": "bun sst deploy",
		"mcp-inspect": "NODE_TLS_REJECT_UNAUTHORIZED='0' bun --cwd packages/backend mcp-inspect",
		"db:generate": "turbo db:generate",
		"db:migrate": "turbo db:migrate",
		"db:deploy": "turbo db:deploy",
		"db:studio": "turbo db:studio",
		"db:push": "turbo db:push",
		"extract-env": "npx sst shell -- bun --cwd packages/db run extract-env"
	},
	"engines": {
		"node": ">=22.0.0"
	},
	"packageManager": "bun@1.2.12",
	"trustedDependencies": ["@biomejs/biome", "aws-sdk", "esbuild"]
}
