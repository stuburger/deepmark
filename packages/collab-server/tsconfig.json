{
	"$schema": "https://json.schemastore.org/tsconfig",
	"extends": "../../tsconfig.json",
	"compilerOptions": {
		"strict": true,
		"skipLibCheck": true,
		"module": "esnext",
		"target": "es2022",
		"moduleResolution": "bundler",
		"baseUrl": ".",
		"paths": {
			"@/*": ["./src/*"]
		}
	},
	"include": ["src/**/*.ts", "sst-env.d.ts"],
	"exclude": ["node_modules"]
}
