{
  "name": "@mcp-gcse/db",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "scripts": {
    "build": "echo 'DB package build is Prisma generate'",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo",
    "extract-env": "bun run scripts/extract-env.ts",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:push": "prisma db push"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.0.2",
    "@prisma/adapter-neon": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@types/ws": "^8.18.1",
    "dotenv": "^17.2.3",
    "prisma": "^7.5.0"
  }
}
