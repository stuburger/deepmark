generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Subject {
  biology
  chemistry
  physics
  english
  business
}

enum DifficultyLevel {
  easy
  medium
  hard
  expert
}

enum MarkingStatus {
  pending
  completed
  failed
}

enum TierLevel {
  foundation
  higher
}

enum Season {
  summer
  autumn
  winter
}

enum UserRole {
  student
  teacher
  admin
  examiner
}

enum QuestionType {
  written
  multiple_choice
}

enum ScanStatus {
  pending
  processing
  ocr_complete
  extracting
  extracted
  failed
}

enum AnswerSource {
  typed
  scanned
}

enum PdfDocumentType {
  mark_scheme
  exemplar
}

enum MarkingMethod {
  deterministic
  point_based
  level_of_response
}

model User {
  id         String   @id @default(cuid())
  email      String?  @unique
  name       String?
  role       UserRole
  github_id  String?  @unique
  avatar_url String?
  is_active  Boolean  @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  created_questions      Question[]
  created_question_parts QuestionPart[]
  created_exam_papers    ExamPaper[]
  created_mark_schemes   MarkScheme[]
  created_exam_sections  ExamSection[]
  created_question_banks QuestionBank[]

  student_answers   Answer[]           @relation("StudentAnswers")
  scan_submissions  ScanSubmission[]   @relation("StudentScans")
  pdf_ingestion_jobs PdfIngestionJob[] @relation("PdfIngestionJobUploader")

  @@map("users")
}

model Question {
  id                          String          @id @default(cuid())
  text                        String
  topic                       String
  created_by_id               String
  created_at                  DateTime        @default(now())
  updated_at                  DateTime        @updatedAt
  subject                     Subject
  points                      Int?
  difficulty_level            DifficultyLevel?
  question_type               QuestionType    @default(written)
  // Array of { option_label, option_text } objects
  multiple_choice_options     Json            @default("[]")
  embedding                   Unsupported("vector(1536)")?
  source_pdf_ingestion_job_id String?

  created_by                  User                  @relation(fields: [created_by_id], references: [id])
  question_parts              QuestionPart[]
  mark_schemes                MarkScheme[]
  answers                     Answer[]
  exam_section_questions      ExamSectionQuestion[]
  question_bank_items         QuestionBankItem[]
  extracted_answers           ExtractedAnswer[]
  source_pdf_ingestion_job    PdfIngestionJob?     @relation("QuestionSource", fields: [source_pdf_ingestion_job_id], references: [id])
  exemplar_answers            ExemplarAnswer[]

  @@map("questions")
}

model QuestionPart {
  id                      String          @id @default(cuid())
  question_id             String
  part_label              String
  text                    String
  points                  Int?
  difficulty_level        DifficultyLevel?
  order                   Int
  created_by_id           String
  created_at              DateTime        @default(now())
  updated_at              DateTime        @updatedAt
  question_type           QuestionType    @default(written)
  // Array of { option_label, option_text } objects
  multiple_choice_options Json            @default("[]")

  created_by        User             @relation(fields: [created_by_id], references: [id])
  question          Question         @relation(fields: [question_id], references: [id])
  mark_schemes      MarkScheme[]
  answers           Answer[]
  extracted_answers ExtractedAnswer[]
  exemplar_answers  ExemplarAnswer[]

  @@map("question_parts")
}

model MarkScheme {
  id                    String        @id @default(cuid())
  question_id           String
  question_part_id      String?
  description           String
  guidance              String?
  created_by_id         String
  created_at            DateTime      @default(now())
  updated_at            DateTime      @updatedAt
  tags                  String[]
  points_total          Int
  // Array of { point_number, description, points, criteria } objects
  mark_points           Json          @default("[]")
  correct_option_labels String[]
  marking_method        MarkingMethod @default(point_based)
  // For level_of_response: { command_word?, items_required?, levels[], caps[] }
  marking_rules         Json?
  refined_at            DateTime?
  refinement_iterations Int            @default(0)

  created_by      User               @relation(fields: [created_by_id], references: [id])
  question        Question           @relation(fields: [question_id], references: [id])
  question_part   QuestionPart?     @relation(fields: [question_part_id], references: [id])
  marking_results MarkingResult[]
  test_runs       MarkSchemeTestRun[]
  exemplar_answers ExemplarAnswer[]

  @@map("mark_schemes")
}

model Answer {
  id                  String        @id @default(cuid())
  question_id         String
  question_part_id    String?
  student_id          String
  student_answer      String
  submitted_at        DateTime      @default(now())
  marked_at           DateTime?
  total_score         Int?
  max_possible_score  Int
  marking_status      MarkingStatus @default(pending)
  source              AnswerSource  @default(typed)

  student          User            @relation("StudentAnswers", fields: [student_id], references: [id])
  question         Question        @relation(fields: [question_id], references: [id])
  question_part    QuestionPart?   @relation(fields: [question_part_id], references: [id])
  marking_results  MarkingResult[]
  extracted_answer ExtractedAnswer?

  @@map("answers")
}

model MarkingResult {
  id                    String   @id @default(cuid())
  answer_id             String
  mark_scheme_id        String
  // Array of { point_number, awarded, reasoning, expected_criteria, student_covered } objects
  mark_points_results   Json     @default("[]")
  total_score           Int
  max_possible_score    Int
  marked_at             DateTime @default(now())
  llm_reasoning         String
  feedback_summary      String
  level_awarded         Int?
  why_not_next_level    String?
  cap_applied           String?

  answer      Answer     @relation(fields: [answer_id], references: [id])
  mark_scheme MarkScheme @relation(fields: [mark_scheme_id], references: [id])

  @@map("marking_results")
}

model ExamPaper {
  id               String   @id @default(cuid())
  title            String
  subject          Subject
  exam_board       String?
  year             Int
  paper_number     Int?
  total_marks      Int
  duration_minutes Int
  created_by_id    String
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt
  is_active        Boolean  @default(true)
  // { difficulty_level?, tier?, season? }
  metadata         Json?

  created_by       User              @relation(fields: [created_by_id], references: [id])
  sections         ExamSection[]
  scan_submissions ScanSubmission[]

  @@map("exam_papers")
}

model ExamSection {
  id            String   @id @default(cuid())
  exam_paper_id String
  title         String
  description   String?
  total_marks   Int
  instructions  String?
  order         Int
  created_by_id String
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  created_by             User                  @relation(fields: [created_by_id], references: [id])
  exam_paper             ExamPaper             @relation(fields: [exam_paper_id], references: [id])
  exam_section_questions ExamSectionQuestion[]

  @@unique([exam_paper_id, title])
  @@map("exam_sections")
}

model ExamSectionQuestion {
  id              String @id @default(cuid())
  exam_section_id String
  question_id     String
  order           Int

  exam_section ExamSection @relation(fields: [exam_section_id], references: [id])
  question     Question    @relation(fields: [question_id], references: [id])

  @@unique([exam_section_id, question_id])
  @@unique([exam_section_id, order])
  @@map("exam_section_questions")
}

model ScanSubmission {
  id               String     @id @default(cuid())
  student_id       String
  exam_paper_id    String
  status           ScanStatus @default(pending)
  page_count       Int
  uploaded_at      DateTime   @default(now())
  processed_at     DateTime?
  error_message    String?
  // { source: "photo"|"scan", notes? }
  metadata         Json?

  student      User         @relation("StudentScans", fields: [student_id], references: [id])
  exam_paper   ExamPaper    @relation(fields: [exam_paper_id], references: [id])
  pages        ScanPage[]

  @@map("scan_submissions")
}

model ScanPage {
  id                 String     @id @default(cuid())
  scan_submission_id String
  page_number        Int
  s3_key             String
  s3_bucket          String
  width_px           Int?
  height_px          Int?
  ocr_status         ScanStatus @default(pending)
  // Full Gemini response: { transcript, features[], observations[] }
  ocr_result         Json?
  processed_at       DateTime?
  error_message      String?

  scan_submission   ScanSubmission    @relation(fields: [scan_submission_id], references: [id])
  extracted_answers ExtractedAnswer[]

  @@unique([scan_submission_id, page_number])
  @@map("scan_pages")
}

model ExtractedAnswer {
  id               String    @id @default(cuid())
  scan_page_id     String
  question_id      String
  question_part_id String?
  extracted_text   String
  // [{ box_2d: [y,x,y,x], label, feature_type }]
  bounding_boxes   Json
  confidence       Float?
  // Null until teacher confirms
  answer_id        String?   @unique
  created_at       DateTime  @default(now())

  scan_page     ScanPage      @relation(fields: [scan_page_id], references: [id])
  question      Question      @relation(fields: [question_id], references: [id])
  question_part QuestionPart?  @relation(fields: [question_part_id], references: [id])
  answer        Answer?       @relation(fields: [answer_id], references: [id])

  @@map("extracted_answers")
}

model QuestionBank {
  id            String   @id @default(cuid())
  name          String
  description   String?
  subject       Subject
  created_by_id String
  is_public     Boolean  @default(false)
  tags          String[]
  is_active     Boolean  @default(true)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  created_by          User               @relation(fields: [created_by_id], references: [id])
  question_bank_items QuestionBankItem[]

  @@map("question_banks")
}

model QuestionBankItem {
  id               String   @id @default(cuid())
  question_bank_id String
  question_id      String
  order            Int
  added_at         DateTime @default(now())

  question_bank QuestionBank @relation(fields: [question_bank_id], references: [id])
  question      Question     @relation(fields: [question_id], references: [id])

  @@unique([question_bank_id, question_id])
  @@unique([question_bank_id, order])
  @@map("question_bank_items")
}

model PdfIngestionJob {
  id                           String          @id @default(cuid())
  document_type                PdfDocumentType
  s3_key                       String
  s3_bucket                    String
  status                       ScanStatus      @default(pending)
  uploaded_by                  String
  exam_board                   String
  subject                      Subject?
  year                         Int?
  paper_reference              String?
  attempt_count                Int             @default(0)
  auto_create_exam_paper       Boolean         @default(true)
  detected_exam_paper_metadata Json?
  error                        String?
  created_at                   DateTime        @default(now())
  processed_at                 DateTime?

  uploader          User             @relation("PdfIngestionJobUploader", fields: [uploaded_by], references: [id])
  exemplars         ExemplarAnswer[]
  created_questions Question[]       @relation("QuestionSource")

  @@map("pdf_ingestion_jobs")
}

model ExemplarAnswer {
  id                   String   @id @default(cuid())
  pdf_ingestion_job_id String
  question_id          String?
  question_part_id     String?
  mark_scheme_id       String?
  raw_question_text    String
  source_exam_board    String
  level                Int
  is_fake_exemplar     Boolean  @default(false)
  answer_text          String
  word_count           Int?
  why_criteria        String[]
  mark_band            String?
  expected_score       Int?
  created_at           DateTime @default(now())

  pdf_ingestion_job PdfIngestionJob @relation(fields: [pdf_ingestion_job_id], references: [id])
  question          Question?       @relation(fields: [question_id], references: [id])
  question_part     QuestionPart?   @relation(fields: [question_part_id], references: [id])
  mark_scheme       MarkScheme?     @relation(fields: [mark_scheme_id], references: [id])
  test_runs         MarkSchemeTestRun[]

  @@map("exemplar_answers")
}

model MarkSchemeTestRun {
  id               String   @id @default(cuid())
  mark_scheme_id   String
  iteration        Int
  target_score     Int
  actual_score     Int
  delta            Int
  student_answer   String
  grader_reasoning String
  schema_patch     String?
  converged        Boolean  @default(false)
  triggered_by     String   @default("pdf_pipeline")
  exemplar_id      String?
  created_at       DateTime @default(now())

  mark_scheme MarkScheme      @relation(fields: [mark_scheme_id], references: [id])
  exemplar    ExemplarAnswer? @relation(fields: [exemplar_id], references: [id])

  @@map("mark_scheme_test_runs")
}
