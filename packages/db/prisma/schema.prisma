generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Subject {
  biology
  chemistry
  physics
  english
  english_literature
  mathematics
  history
  geography
  computer_science
  french
  spanish
  religious_studies
  business
}

enum DifficultyLevel {
  easy
  medium
  hard
  expert
}

enum MarkingStatus {
  pending
  completed
  failed
}

enum TierLevel {
  foundation
  higher
}

enum BoundaryMode {
  percent
  raw
}

enum Season {
  summer
  autumn
  winter
}

enum UserRole {
  student
  teacher
  admin
  examiner
}

enum QuestionType {
  written
  multiple_choice
}

enum ScanStatus {
  pending
  processing
  text_extracted
  ocr_complete
  grading
  failed
  cancelled
}

enum AnnotationSource {
  ai
  teacher
}

enum OcrStatus {
  pending
  processing
  complete
  failed
  cancelled
}

enum GradingStatus {
  pending
  processing
  complete
  failed
  cancelled
}

enum AnswerSource {
  typed
  scanned
}

enum PdfDocumentType {
  mark_scheme
  exemplar
  question_paper
}

enum QuestionOrigin {
  mark_scheme
  exemplar
  question_paper
  manual
}

enum MarkingMethod {
  deterministic
  point_based
  level_of_response
}

enum MarkSchemeStatus {
  linked
  auto_linked
  unlinked
}

enum BatchStatus {
  uploading
  classifying
  staging
  marking
  complete
  failed
}

enum ReviewMode {
  auto
  required
}

enum BlankPageMode {
  script_page
  separator
}

enum StagedScriptStatus {
  proposed
  confirmed
  excluded
  submitted
}

enum ClassificationMode {
  auto
  per_file
  fixed_pages
  blank_separator
}

enum StimulusContentType {
  text
  image
  table
}

model User {
  id         String   @id @default(cuid())
  email      String?  @unique
  name       String?
  role       UserRole
  github_id  String?  @unique
  avatar_url String?
  is_active  Boolean  @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  created_questions      Question[]
  created_exam_papers    ExamPaper[]
  created_mark_schemes   MarkScheme[]
  created_exam_sections  ExamSection[]
  created_stimuli        Stimulus[]
  created_question_banks QuestionBank[]

  students             Student[]              @relation("TeacherStudents")
  pdf_ingestion_jobs   PdfIngestionJob[]      @relation("PdfIngestionJobUploader")
  student_submissions  StudentSubmission[]    @relation("SubmissionUploader")
  batch_ingest_jobs    BatchIngestJob[]       @relation("BatchIngestJobUploader")
  push_subscriptions   UserPushSubscription[] @relation("UserPushSubscriptions")
  teacher_overrides    TeacherOverride[]      @relation("UserOverrides")
  submission_feedback  SubmissionFeedback[]   @relation("UserFeedback")

  @@map("users")
}

model Question {
  id                          String                       @id @default(cuid())
  text                        String
  topic                       String
  created_by_id               String
  created_at                  DateTime                     @default(now())
  updated_at                  DateTime                     @updatedAt
  subject                     Subject
  points                      Int?
  difficulty_level            DifficultyLevel?
  question_type               QuestionType                 @default(written)
  origin                      QuestionOrigin               @default(mark_scheme)
  // Array of { option_label, option_text } objects
  multiple_choice_options     Json                         @default("[]")
  embedding                   Unsupported("vector(1536)")?
  source_pdf_ingestion_job_id String?
  // Canonical question number extracted from PDF e.g. "1a", "2bii", "3"
  question_number             String?

  // ── Sub-part grouping (replaces QuestionPart table) ──
  // Grouping key for display (e.g., "2" for questions "2a", "2b", "2c").
  // NOTE: question-level stimulus/context lives in the Stimulus +
  // QuestionStimulus tables, not on the question itself — one stimulus
  // can be referenced by multiple questions.
  parent_number               String?
  // Sub-question designator (e.g., "a", "b", "i", "ii")
  part_label                  String?

  created_by               User                  @relation(fields: [created_by_id], references: [id])
  mark_schemes             MarkScheme[]
  answers                  Answer[]
  exam_section_questions   ExamSectionQuestion[]
  question_stimuli         QuestionStimulus[]
  question_bank_items      QuestionBankItem[]
  source_pdf_ingestion_job PdfIngestionJob?      @relation("QuestionSource", fields: [source_pdf_ingestion_job_id], references: [id])
  exemplar_answers         ExemplarAnswer[]

  // Explicit cross-question dependencies (e.g., "1b refers to 1a")
  depends_on               Question[]            @relation("QuestionDependency")
  depended_by              Question[]            @relation("QuestionDependency")

  @@map("questions")
}

model MarkScheme {
  id                    String           @id @default(cuid())
  question_id           String
  description           String
  guidance              String?
  created_by_id         String
  created_at            DateTime         @default(now())
  updated_at            DateTime         @updatedAt
  tags                  String[]
  points_total          Int
  // Array of { point_number, description, points, criteria } objects
  mark_points           Json             @default("[]")
  correct_option_labels String[]
  marking_method        MarkingMethod    @default(point_based)
  // Rich markdown content — indicative content, exemplar answers, marker notes, level descriptors.
  // Primary source of question-specific marking guidance for LoR; optional for point_based/deterministic.
  content               String           @default("")
  link_status           MarkSchemeStatus @default(linked)
  refined_at            DateTime?
  refinement_iterations Int              @default(0)

  created_by       User                @relation(fields: [created_by_id], references: [id])
  question         Question            @relation(fields: [question_id], references: [id])
  marking_results  MarkingResult[]
  test_runs        MarkSchemeTestRun[]
  exemplar_answers ExemplarAnswer[]

  @@map("mark_schemes")
}

model Student {
  id         String   @id @default(cuid())
  name       String
  class_name String?
  year_group String?
  teacher_id String
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  teacher              User                @relation("TeacherStudents", fields: [teacher_id], references: [id])
  answers              Answer[]            @relation("StudentAnswers")
  student_submissions  StudentSubmission[] @relation("SubmissionStudent")

  @@map("students")
}

model Answer {
  id                 String        @id @default(cuid())
  question_id        String
  student_id         String
  student_answer     String
  submitted_at       DateTime      @default(now())
  marked_at          DateTime?
  total_score        Int?
  max_possible_score Int
  marking_status     MarkingStatus @default(pending)
  source             AnswerSource  @default(typed)

  student         Student         @relation("StudentAnswers", fields: [student_id], references: [id])
  question        Question        @relation(fields: [question_id], references: [id])
  marking_results MarkingResult[]

  @@map("answers")
}

model MarkingResult {
  id                  String   @id @default(cuid())
  answer_id           String
  mark_scheme_id      String
  // Array of { point_number, awarded, reasoning, expected_criteria, student_covered } objects
  mark_points_results Json     @default("[]")
  total_score         Int
  max_possible_score  Int
  marked_at           DateTime @default(now())
  llm_reasoning       String
  feedback_summary    String
  level_awarded       Int?
  why_not_next_level  String?
  cap_applied         String?
  answer      Answer     @relation(fields: [answer_id], references: [id])
  mark_scheme MarkScheme @relation(fields: [mark_scheme_id], references: [id])

  @@map("marking_results")
}

model ExamPaper {
  id               String   @id @default(cuid())
  title            String
  subject          Subject
  exam_board       String?
  year             Int
  paper_number     Int?
  total_marks      Int
  duration_minutes Int
  created_by_id    String
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt
  is_active        Boolean  @default(true)
  is_public        Boolean  @default(false)
  // { difficulty_level?, season? }. `tier` was promoted to a first-class column
  // in April 2026; legacy rows may still carry `metadata.tier`.
  metadata         Json?
  tier             TierLevel?
  /// Optional GCSE grade boundaries, shape GradeBoundary[] from @mcp-gcse/shared.
  /// Interpretation (percent of total vs raw marks) is given by grade_boundary_mode.
  /// Null when unset. Validated at the server-action boundary.
  grade_boundaries      Json?
  grade_boundary_mode   BoundaryMode?
  /// Marking Guidance — teacher-authored freetext injected into LoR grading prompts.
  /// Supports level descriptors, feedback style instructions, and few-shot examples.
  /// Displayed in the UI as "Marking Guidance". Future: rename column to marking_guidance.
  level_descriptors String?

  created_by           User                @relation(fields: [created_by_id], references: [id])
  sections             ExamSection[]
  stimuli              Stimulus[]
  pdf_ingestion_jobs   PdfIngestionJob[]
  student_submissions  StudentSubmission[] @relation("SubmissionExamPaper")
  batch_ingest_jobs    BatchIngestJob[]

  @@map("exam_papers")
}

model ExamSection {
  id            String   @id @default(cuid())
  exam_paper_id String
  title         String
  description   String?
  total_marks   Int
  instructions  String?
  order         Int
  created_by_id String
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  created_by             User                  @relation(fields: [created_by_id], references: [id])
  exam_paper             ExamPaper             @relation(fields: [exam_paper_id], references: [id])
  exam_section_questions ExamSectionQuestion[]

  @@unique([exam_paper_id, title])
  @@map("exam_sections")
}

model ExamSectionQuestion {
  id              String @id @default(cuid())
  exam_section_id String
  question_id     String
  order           Int

  exam_section ExamSection @relation(fields: [exam_section_id], references: [id])
  question     Question    @relation(fields: [question_id], references: [id])

  @@unique([exam_section_id, question_id])
  @@unique([exam_section_id, order])
  @@map("exam_section_questions")
}

/// Stimulus = a case study / source / item / figure / table referenced by one
/// or more questions. Scoped to an exam paper; referenced via QuestionStimulus.
/// Extraction populates `label` with the paper's printed name ("Item A",
/// "Source B", "Figure 1"); `content` currently holds plain-text/markdown
/// extract. `content_type` is future-proofing for images/tables.
model Stimulus {
  id            String              @id @default(cuid())
  exam_paper_id String
  /// As printed on the paper — "Item A", "Source B", "Figure 1", "Table 2".
  label         String
  /// Full text/markdown of the case study. For image stimuli this is an S3 key;
  /// for table stimuli this is markdown-formatted.
  content       String
  content_type  StimulusContentType @default(text)
  /// Display order within the paper (Item A before Item B).
  order         Int
  created_by_id String
  created_at    DateTime            @default(now())
  updated_at    DateTime            @updatedAt

  created_by       User               @relation(fields: [created_by_id], references: [id])
  exam_paper       ExamPaper          @relation(fields: [exam_paper_id], references: [id])
  question_stimuli QuestionStimulus[]

  @@unique([exam_paper_id, label])
  @@map("stimuli")
}

/// Many-to-many join between Question and Stimulus. `order` disambiguates when
/// a single question references multiple stimuli (e.g. "Using Source A and
/// Source B…" — Source A is order=1, Source B order=2).
model QuestionStimulus {
  id          String @id @default(cuid())
  question_id String
  stimulus_id String
  order       Int

  question Question @relation(fields: [question_id], references: [id])
  stimulus Stimulus @relation(fields: [stimulus_id], references: [id])

  @@unique([question_id, stimulus_id])
  @@map("question_stimuli")
}

model QuestionBank {
  id            String   @id @default(cuid())
  name          String
  description   String?
  subject       Subject
  created_by_id String
  is_public     Boolean  @default(false)
  tags          String[]
  is_active     Boolean  @default(true)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  created_by          User               @relation(fields: [created_by_id], references: [id])
  question_bank_items QuestionBankItem[]

  @@map("question_banks")
}

model QuestionBankItem {
  id               String   @id @default(cuid())
  question_bank_id String
  question_id      String
  order            Int
  added_at         DateTime @default(now())

  question_bank QuestionBank @relation(fields: [question_bank_id], references: [id])
  question      Question     @relation(fields: [question_id], references: [id])

  @@unique([question_bank_id, question_id])
  @@unique([question_bank_id, order])
  @@map("question_bank_items")
}

model PdfIngestionJob {
  id                           String          @id @default(cuid())
  document_type                PdfDocumentType
  s3_key                       String
  s3_bucket                    String
  status                       ScanStatus      @default(pending)
  uploaded_by                  String
  exam_board                   String
  subject                      Subject?
  year                         Int?
  paper_reference              String?
  attempt_count                Int             @default(0)
  auto_create_exam_paper       Boolean         @default(true)
  run_adversarial_loop         Boolean         @default(false)
  detected_exam_paper_metadata Json?
  exam_paper_id                String?
  // Multi-page support: [{ key: string, order: number, mime_type: string }]
  pages                        Json?
  // Ordered append-only event log: [{ type, at, ...payload }]
  job_events                   Json?
  error                        String?
  created_at                   DateTime        @default(now())
  processed_at                 DateTime?

  uploader          User             @relation("PdfIngestionJobUploader", fields: [uploaded_by], references: [id])
  exam_paper        ExamPaper?       @relation(fields: [exam_paper_id], references: [id])
  exemplars         ExemplarAnswer[]
  created_questions Question[]       @relation("QuestionSource")

  @@map("pdf_ingestion_jobs")
}

model StudentPaperAnswerRegion {
  id              String   @id @default(cuid())
  submission_id   String
  question_id     String
  question_number String
  page_order      Int
  // [yMin, xMin, yMax, xMax] normalised 0–1000
  box             Json
  // null = derived from Vision token hull; "gemini_fallback" = Gemini Vision estimate (e.g. MCQ circles)
  source          String?
  created_at      DateTime @default(now())

  submission StudentSubmission @relation("SubmissionAnswerRegions", fields: [submission_id], references: [id])

  @@unique([submission_id, question_id, page_order])
  @@map("student_paper_answer_regions")
}

model StudentPaperPageToken {
  id             String   @id @default(cuid())
  submission_id  String
  page_order     Int
  para_index     Int
  line_index     Int
  word_index     Int
  text_raw       String
  text_corrected String?
  // [yMin, xMin, yMax, xMax] normalised 0-1000 — same coord system as StudentPaperAnswerRegion
  bbox           Json
  confidence     Float?
  question_id    String?
  /// Character offset (start) in student_answer where this token aligns. Null if unaligned.
  answer_char_start Int?
  /// Character offset (end, exclusive) in student_answer where this token aligns.
  answer_char_end   Int?
  created_at     DateTime @default(now())

  submission StudentSubmission @relation("SubmissionWordTokens", fields: [submission_id], references: [id])

  @@index([submission_id, page_order])
  @@map("student_paper_page_tokens")
}

model StudentPaperAnnotation {
  id              String   @id @default(cuid())
  /// Null for teacher-authored annotations (source=teacher). Set to the owning GradingRun for AI annotations.
  grading_run_id  String?
  /// Owning submission. Always set — required for every annotation.
  submission_id     String
  /// Origin of the annotation — AI pipeline or teacher edit.
  source            AnnotationSource @default(ai)
  /// Soft-delete timestamp. Null = active.
  deleted_at        DateTime?
  question_id     String
  page_order      Int

  /// Overlay type: "annotation" | "chain"
  overlay_type    String
  /// Sentiment for color coding: "positive" | "negative" | "neutral"
  sentiment       String?

  /// Typed payload — shape determined by overlay_type, validated by Zod at app layer
  payload         Json

  /// Spatial anchoring — references to StudentPaperPageToken IDs
  anchor_token_start_id String?
  anchor_token_end_id   String?
  /// Bounding box [yMin, xMin, yMax, xMax] normalised 0-1000
  bbox                  Json

  sort_order      Int      @default(0)
  created_at      DateTime @default(now())
  updated_at      DateTime? @updatedAt

  grading_run     GradingRun?       @relation("GradingRunAnnotations", fields: [grading_run_id], references: [id], onDelete: Cascade)
  submission      StudentSubmission @relation("SubmissionAnnotations", fields: [submission_id], references: [id])

  @@index([grading_run_id, page_order])
  @@index([grading_run_id, question_id])
  @@index([submission_id, deleted_at])
  @@map("student_paper_annotations")
}

model StudentSubmission {
  id               String   @id @default(cuid())
  s3_key           String
  s3_bucket        String
  uploaded_by      String
  exam_board       String
  exam_paper_id    String
  pages            Json
  student_name     String?
  student_id       String?
  subject          Subject?
  year             Int?
  paper_reference  String?
  detected_subject Subject?
  batch_job_id     String?
  staged_script_id String?
  created_at       DateTime @default(now())
  /// Set when this submission is superseded by a re-scan/re-mark. Superseded submissions are excluded from lists and analytics.
  superseded_at     DateTime?
  /// Why this submission was superseded (e.g. "re-scan", "re-grade"). Null for the current (non-superseded) version.
  supersede_reason  String?

  uploader      User                       @relation("SubmissionUploader", fields: [uploaded_by], references: [id])
  exam_paper    ExamPaper                  @relation("SubmissionExamPaper", fields: [exam_paper_id], references: [id])
  student       Student?                   @relation("SubmissionStudent", fields: [student_id], references: [id])
  batch_job     BatchIngestJob?            @relation("BatchIngestSubmissions", fields: [batch_job_id], references: [id])
  staged_script StagedScript?             @relation("StagedScriptSubmission", fields: [staged_script_id], references: [id])
  ocr_runs      OcrRun[]
  grading_runs  GradingRun[]
  word_tokens   StudentPaperPageToken[]   @relation("SubmissionWordTokens")
  answer_regions     StudentPaperAnswerRegion[] @relation("SubmissionAnswerRegions")
  teacher_overrides  TeacherOverride[]          @relation("SubmissionOverrides")
  feedback           SubmissionFeedback[]       @relation("SubmissionFeedback")
  annotations        StudentPaperAnnotation[]   @relation("SubmissionAnnotations")

  @@map("student_submissions")
}

model OcrRun {
  id                    String    @id @default(cuid())
  submission_id         String
  status                OcrStatus @default(pending)
  error                 String?
  // Raw OCR extraction: { student_name?, answers: [{question_number, answer_text}] }
  extracted_answers_raw Json?
  // Per-page OCR analysis: [{ page: number, transcript: string, observations: string[] }]
  page_analyses         Json?
  // S3 key for the raw Cloud Vision API response
  vision_raw_s3_key     String?
  // Ordered append-only event log
  job_events            Json?
  // LlmRunSnapshot — which models were configured and which executed
  llm_snapshot          Json?
  started_at            DateTime?
  completed_at          DateTime?
  created_at            DateTime  @default(now())

  submission   StudentSubmission @relation(fields: [submission_id], references: [id])
  grading_runs GradingRun[]

  @@index([submission_id])
  @@map("ocr_runs")
}

model GradingRun {
  id            String        @id @default(cuid())
  submission_id String
  ocr_run_id    String
  status        GradingStatus @default(pending)
  error         String?
  grading_results Json?
  // Ordered append-only event log
  job_events    Json?
  // 3-line LLM-generated student summary (strength / weakness / improvement)
  examiner_summary String?
  // LlmRunSnapshot — which models were configured and which executed
  llm_snapshot  Json?
  /// LlmRunSnapshot for the annotation step (runs inside the grade Lambda).
  annotation_llm_snapshot  Json?
  /// Error message if the annotation step failed. Grading can succeed even if this is set.
  annotation_error         String?
  /// Timestamp when the annotation step finished. Null while annotation has not completed.
  annotations_completed_at DateTime?
  started_at    DateTime?
  completed_at  DateTime?
  created_at    DateTime      @default(now())

  submission StudentSubmission        @relation(fields: [submission_id], references: [id])
  ocr_run    OcrRun                   @relation(fields: [ocr_run_id], references: [id])
  annotations StudentPaperAnnotation[] @relation("GradingRunAnnotations")
  feedback   SubmissionFeedback[]     @relation("GradingRunFeedback")

  @@index([submission_id])
  @@index([ocr_run_id])
  @@map("grading_runs")
}

model ExemplarAnswer {
  id                   String   @id @default(cuid())
  pdf_ingestion_job_id String
  question_id          String?
  mark_scheme_id       String?
  raw_question_text    String
  source_exam_board    String
  level                Int
  is_fake_exemplar     Boolean  @default(false)
  answer_text          String
  word_count           Int?
  why_criteria         String[]
  mark_band            String?
  expected_score       Int?
  created_at           DateTime @default(now())

  pdf_ingestion_job PdfIngestionJob     @relation(fields: [pdf_ingestion_job_id], references: [id])
  question          Question?           @relation(fields: [question_id], references: [id])
  mark_scheme       MarkScheme?         @relation(fields: [mark_scheme_id], references: [id])
  test_runs         MarkSchemeTestRun[]

  @@map("exemplar_answers")
}

model MarkSchemeTestRun {
  id               String   @id @default(cuid())
  mark_scheme_id   String
  iteration        Int
  target_score     Int
  actual_score     Int
  delta            Int
  student_answer   String
  grader_reasoning String
  schema_patch     String?
  converged        Boolean  @default(false)
  triggered_by     String   @default("pdf_pipeline")
  exemplar_id      String?
  created_at       DateTime @default(now())

  mark_scheme MarkScheme      @relation(fields: [mark_scheme_id], references: [id])
  exemplar    ExemplarAnswer? @relation(fields: [exemplar_id], references: [id])

  @@map("mark_scheme_test_runs")
}

model BatchIngestJob {
  id                   String             @id @default(cuid())
  exam_paper_id        String
  uploaded_by          String
  status               BatchStatus        @default(uploading)
  review_mode          ReviewMode         @default(auto)
  blank_page_mode      BlankPageMode      @default(script_page)
  pages_per_script     Int                @default(4)
  classification_mode  ClassificationMode @default(auto)
  total_student_jobs   Int           @default(0)
  notification_sent_at DateTime?
  error                String?
  job_events           Json?
  created_at           DateTime      @default(now())
  processed_at         DateTime?

  uploader            User                @relation("BatchIngestJobUploader", fields: [uploaded_by], references: [id])
  exam_paper          ExamPaper           @relation(fields: [exam_paper_id], references: [id])
  student_submissions StudentSubmission[] @relation("BatchIngestSubmissions")
  staged_scripts      StagedScript[]

  @@map("batch_ingest_jobs")
}

model StagedScript {
  id             String             @id @default(cuid())
  batch_job_id   String
  // [{ s3_key, order, mime_type, source_file }]
  page_keys      Json
  proposed_name  String?
  confidence     Float?
  confirmed_name String?
  status         StagedScriptStatus @default(proposed)
  created_at     DateTime           @default(now())

  batch_job           BatchIngestJob      @relation(fields: [batch_job_id], references: [id])
  student_submissions StudentSubmission[] @relation("StagedScriptSubmission")

  @@map("staged_scripts")
}

model SubmissionFeedback {
  id            String   @id @default(cuid())
  submission_id String
  /// "positive" or "negative" — thumbs up / thumbs down
  rating        String
  /// What was wrong (negative only): ["scores", "annotations", "answer_extraction", "feedback_text", "other"]
  categories    Json?
  /// Optional free-text comment from the teacher
  comment       String?
  /// Snapshot of which grading run was active when feedback was given
  grading_run_id String?
  created_by    String
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  submission      StudentSubmission @relation("SubmissionFeedback", fields: [submission_id], references: [id], onDelete: Cascade)
  grading_run     GradingRun?       @relation("GradingRunFeedback", fields: [grading_run_id], references: [id])
  created_by_user User              @relation("UserFeedback", fields: [created_by], references: [id])

  @@unique([submission_id, created_by])
  @@index([submission_id])
  @@map("submission_feedback")
}

model TeacherOverride {
  id                     String   @id @default(cuid())
  submission_id          String
  question_id            String
  score_override         Int
  reason                 String?
  feedback_override      String?
  created_by             String
  created_at             DateTime @default(now())
  updated_at             DateTime @updatedAt

  submission      StudentSubmission @relation("SubmissionOverrides", fields: [submission_id], references: [id], onDelete: Cascade)
  created_by_user User              @relation("UserOverrides", fields: [created_by], references: [id])

  @@unique([submission_id, question_id])
  @@index([submission_id])
  @@map("teacher_overrides")
}

model UserPushSubscription {
  id         String   @id @default(cuid())
  user_id    String
  endpoint   String   @unique
  p256dh     String
  auth       String
  user_agent String?
  created_at DateTime @default(now())

  user User @relation("UserPushSubscriptions", fields: [user_id], references: [id])

  @@index([user_id])
  @@map("user_push_subscriptions")
}

model LlmCallSite {
  id           String   @id @default(cuid())
  key          String   @unique
  display_name String
  description  String?
  input_type   String   // "text" | "vision" | "pdf"
  phase        String?  // pipeline phase for UI grouping: "pdf-ingestion" | "batch-classification" | "ocr" | "grading" | "enrichment" | "tools"
  models       Json     // ordered array of { provider, model, temperature }
  updated_by   String?
  updated_at   DateTime @updatedAt

  @@map("llm_call_sites")
}
