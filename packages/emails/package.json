	},
	"dependencies": {
		"@react-email/components": "0.0.36",
		"@react-email/render": "1.0.6"
	},
	"peerDependencies": {
		"react": "^19.0.0",
		"react-dom": "^19.0.0"
	},
	"devDependencies": {
		"@types/react": "^19.0.0",
		"react": "^19.0.0",
		"react-dom": "^19.0.0",
		"react-email": "4.0.16",
		"typescript": "^5.8.3"
	}
}
