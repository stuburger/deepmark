{
	"$schema": "https://json.schemastore.org/tsconfig",
	"extends": "../../tsconfig.json",
	"compilerOptions": {
		"strict": true,
		"module": "esnext",
		"target": "es2022",
		"moduleResolution": "bundler",
		"jsx": "react-jsx",
		"outDir": "dist",
		"declaration": true,
		"declarationMap": true,
		"rootDir": "src",
		"skipLibCheck": true,
		"esModuleInterop": true,
		"allowSyntheticDefaultImports": true
	},
	"include": ["src/**/*.ts", "src/**/*.tsx"],
	"exclude": ["node_modules", "dist"]
}
