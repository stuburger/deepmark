{
	"$schema": "https://json.schemastore.org/tsconfig",
	"extends": "../../tsconfig.json",
	"compilerOptions": {
		"strict": true,
		"module": "esnext",
		"target": "es2022",
		"moduleResolution": "bundler",
		"outDir": "dist",
		"declaration": true,
		"declarationMap": true,
		"rootDir": "src",
		"skipLibCheck": true
	},
	"include": ["src/**/*.ts"],
	"exclude": ["node_modules"]
}
